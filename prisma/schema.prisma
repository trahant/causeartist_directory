generator client {
  provider        = "prisma-client"
  output          = "../.generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "client"
}

datasource db {
  provider   = "postgresql"
  extensions = [citext, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model User {
  id            String     @id @default(cuid(2))
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  role          String     @default("user")
  banned        Boolean?   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  bookmarks     Bookmark[]
  posts         Post[]
  sessions      Session[]
  tools         Tool[]

  @@index([id])
}

model Session {
  id             String   @id @default(cuid(2))
  userId         String
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid(2))
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid(2))
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid(2))
  email       String
  name        String
  description String?
  websiteUrl  String
  faviconUrl  String?
  type        AdType   @default(All)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  buttonLabel String?
  sessionId   String?
  bannerUrl   String?
}

model Tool {
  id             String     @id @default(cuid(2))
  name           String     @db.Citext
  slug           String     @unique
  websiteUrl     String
  affiliateUrl   String?
  tagline        String?
  description    String?
  content        String?
  faviconUrl     String?
  screenshotUrl  String?
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  ownerId        String?
  tier           ToolTier   @default(Free)
  tierPriority   Int        @default(dbgenerated("\nCASE\n    WHEN (tier = 'Premium'::\"ToolTier\") THEN 0\n    ELSE 1\nEND"))
  bookmarks      Bookmark[]
  reports        Report[]
  owner          User?      @relation(fields: [ownerId], references: [id])
  categories     Category[] @relation("CategoryToTool")
  tags           Tag[]      @relation("TagToTool")

  @@index([id, slug])
  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([tierPriority, publishedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid(2))
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  tools       Tool[]   @relation("CategoryToTool")

  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid(2))
  name      String   @db.Citext
  slug      String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  tools     Tool[]   @relation("TagToTool")

  @@index([name])
}

model Report {
  id        String     @id @default(cuid(2))
  toolId    String?
  type      ReportType @default(Other)
  message   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  email     String     @default("")
  tool      Tool?      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
}

model Bookmark {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

model Post {
  id          String     @id @default(cuid(2))
  title       String     @db.Citext
  slug        String     @unique
  description String?
  content     String
  plainText   String     @default("")
  imageUrl    String?
  status      PostStatus @default(Draft)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}

model Company {
  id              String                  @id @default(cuid())
  name            String
  slug            String                  @unique
  status          String                  @default("draft")
  alternativeRole CompanyAlternativeRole  @default(Hidden)
  alternativesSummary String?
  tagline         String?
  description     String?
  logoUrl         String?
  website         String?
  foundedYear     Int?
  totalFunding    String?
  linkedin        String?
  twitter         String?
  founderName     String?
  impactModel     String?
  impactMetrics   String?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  heroImageUrl    String?
  /// JSON array of `{ "title": string, "body": string }` for structured “key benefits” on the profile.
  keyBenefits     Json?
  lifecycleStatus CompanyLifecycleStatus  @default(Active)
  /// Traditional / incumbent brand — appears in admin “Alternatives (ordered)” picker for impact companies.
  isTraditionalCompany Boolean              @default(false)
  caseStudies     CaseStudy[]
  certifications  CompanyCertification[]
  podcastEpisodes CompanyEpisode[]
  funders         CompanyFunder[]
  locations       CompanyLocation[]
  retailLocations CompanyRetailLocation[]
  alternatives    CompanyAlternative[]    @relation("CompanyAlternatives")
  alternativeOf   CompanyAlternative[]    @relation("CompanyAlternativeTargets")
  sectors         CompanySector[]
  subcategories   CompanySubcategory[]
}

model Funder {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  status           String              @default("draft")
  type             String?
  description      String?
  logoUrl          String?
  website          String?
  foundedYear      Int?
  aum              String?
  checkSizeMin     Int?
  checkSizeMax     Int?
  investmentThesis String?
  applicationUrl   String?
  linkedin         String?
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  heroImageUrl     String?
  /// JSON array of `{ "title": string, "body": string }` for structured “key benefits” on the profile.
  keyBenefits      Json?
  portfolio        CompanyFunder[]
  podcastEpisodes  FunderEpisode[]
  locations        FunderLocation[]
  sectors          FunderSector[]
  stages           FunderStage[]
  subcategories    FunderSubcategory[]
}

model Sector {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  heroText  String?
  createdAt DateTime        @default(now())
  companies CompanySector[]
  funders   FunderSector[]
}

model Subcategory {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now())
  companies CompanySubcategory[]
  funders   FunderSubcategory[]
}

model Location {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  country     String?
  countryCode String?
  region      String?
  companies   CompanyLocation[]
  funders     FunderLocation[]
}

model FundingStage {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  sortOrder Int           @default(100)
  funders   FunderStage[]
}

model CompanySector {
  companyId String
  sectorId  String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sector    Sector  @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([companyId, sectorId])
}

model CompanyLocation {
  companyId  String
  locationId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([companyId, locationId])
}

/// Physical retail / storefront rows (not directory taxonomy `Location`).
model CompanyRetailLocation {
  id           String   @id @default(cuid())
  companyId    String
  label        String
  addressLine1 String?
  addressLine2 String?
  city         String
  region       String?
  postalCode   String?
  countryCode  String?
  url          String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyFunder {
  companyId String
  funderId  String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  funder    Funder  @relation(fields: [funderId], references: [id], onDelete: Cascade)

  @@id([companyId, funderId])
}

model CompanySubcategory {
  companyId     String
  subcategoryId String
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([companyId, subcategoryId])
}

model CompanyAlternative {
  companyId            String
  alternativeCompanyId String
  sortOrder            Int      @default(0)
  company              Company  @relation("CompanyAlternatives", fields: [companyId], references: [id], onDelete: Cascade)
  alternativeCompany   Company  @relation("CompanyAlternativeTargets", fields: [alternativeCompanyId], references: [id], onDelete: Cascade)

  @@id([companyId, alternativeCompanyId])
  @@index([companyId, sortOrder])
  @@index([alternativeCompanyId])
}

model FunderSector {
  funderId String
  sectorId String
  funder   Funder @relation(fields: [funderId], references: [id], onDelete: Cascade)
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@id([funderId, sectorId])
}

model FunderSubcategory {
  funderId      String
  subcategoryId String
  funder        Funder      @relation(fields: [funderId], references: [id], onDelete: Cascade)
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([funderId, subcategoryId])
}

model FunderStage {
  funderId     String
  stageId      String
  funder       Funder       @relation(fields: [funderId], references: [id], onDelete: Cascade)
  fundingStage FundingStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@id([funderId, stageId])
}

model FunderLocation {
  funderId   String
  locationId String
  funder     Funder   @relation(fields: [funderId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([funderId, locationId])
}

model PodcastEpisode {
  id             String           @id @default(cuid())
  title          String
  slug           String           @unique
  status         String           @default("draft")
  episodeNumber  Int?
  description    String?
  content        String?
  heroImageUrl   String?
  spotifyUrl     String?
  appleUrl       String?
  youtubeUrl     String?
  excerpt        String?
  guestName      String?
  guestTitle     String?
  guestCompany   String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  show           String?
  companies      CompanyEpisode[]
  funders        FunderEpisode[]
}

model CompanyEpisode {
  companyId String
  episodeId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  episode   PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@id([companyId, episodeId])
}

model FunderEpisode {
  funderId  String
  episodeId String
  episode   PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  funder    Funder         @relation(fields: [funderId], references: [id], onDelete: Cascade)

  @@id([funderId, episodeId])
}

model CaseStudy {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  status         String    @default("draft")
  excerpt        String?
  content        String?
  heroImageUrl   String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  canonicalUrl   String?
  ogImageUrl     String?
  ogImageAlt     String?
  metaRobots     String?
  focusKeyword   String?
  secondaryKeywords Json?
  lastReviewedAt DateTime?
  reviewedBy     String?
  sources        Json?
  faqItems       Json?
  keyTakeaways   Json?
  readingTimeMinutes Int?
  contentType    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id])
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  status         String    @default("draft")
  excerpt        String?
  content        String?
  heroImageUrl   String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  canonicalUrl   String?
  ogImageUrl     String?
  ogImageAlt     String?
  metaRobots     String?
  focusKeyword   String?
  secondaryKeywords Json?
  lastReviewedAt DateTime?
  reviewedBy     String?
  sources        Json?
  faqItems       Json?
  keyTakeaways   Json?
  readingTimeMinutes Int?
  contentType    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  authorId       String?
  author         Author?   @relation(fields: [authorId], references: [id])
}

model GlossaryTerm {
  id              String   @id @default(cuid())
  term            String
  slug            String   @unique
  status          String   @default("draft")
  definition      String?
  extendedContent String?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Author {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  bio       String?
  avatarUrl String?
  twitter   String?
  linkedin  String?
  createdAt DateTime   @default(now())
  posts     BlogPost[]
}

model Certification {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  logoUrl     String?
  website     String?
  createdAt   DateTime               @default(now())
  companies   CompanyCertification[]
}

model CompanyCertification {
  companyId       String
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, certificationId])
}

enum CompanyLifecycleStatus {
  Active
  Acquired
  Sunsetted
}

enum CompanyAlternativeRole {
  Target
  Alternative
  Both
  Hidden
}

enum AdType {
  Banner
  Tools
  ToolPage
  BlogPost
  All
  Bottom
}

enum ToolStatus {
  Draft
  Scheduled
  Published
  Pending
}

enum ToolTier {
  Free
  Standard
  Premium
}

enum ReportType {
  BrokenLink
  WrongCategory
  Outdated
  Other
}

enum PostStatus {
  Draft
  Scheduled
  Published
}
