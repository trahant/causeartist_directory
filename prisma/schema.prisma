generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "client"
  output          = "../.generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

enum AdType {
  Banner
  Tools
  ToolPage
  BlogPost
  Bottom
  All
}

enum ToolStatus {
  Draft
  Scheduled
  Pending
  Published
}

enum ToolTier {
  Free
  Standard
  Premium
}

enum ReportType {
  BrokenLink
  WrongCategory
  Outdated
  Other
}

enum PostStatus {
  Draft
  Scheduled
  Published
}

model User {
  id            String    @id @default(cuid(2))
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts  Account[]
  sessions  Session[]
  tools     Tool[]
  posts     Post[]
  bookmarks Bookmark[]

  // Indexes
  @@index([id])
}

model Session {
  id             String   @id @default(cuid(2))
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid(2))
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid(2))
  email       String
  name        String
  description String?
  websiteUrl  String
  faviconUrl  String?
  bannerUrl   String?
  buttonLabel String?
  type        AdType   @default(All)
  startsAt    DateTime
  endsAt      DateTime
  sessionId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id             String     @id @default(cuid(2))
  name           String     @db.Citext
  slug           String     @unique
  websiteUrl     String
  affiliateUrl   String?
  tagline        String?
  description    String?
  content        String?
  faviconUrl     String?
  screenshotUrl  String?
  tier           ToolTier   @default(Free)
  tierPriority   Int        @default(dbgenerated())
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  categories Category[]
  tags       Tag[]
  reports    Report[]
  bookmarks  Bookmark[]
  owner      User?      @relation(fields: [ownerId], references: [id])
  ownerId    String?

  @@index([id, slug])
  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([tierPriority, publishedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid(2))
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Implicit relation
  tools Tool[]

  // Indexes
  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid(2))
  name      String   @db.Citext
  slug      String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relations
  tools Tool[]

  // Indexes
  @@index([name])
}

model Report {
  id        String     @id @default(cuid(2))
  type      ReportType @default(Other)
  message   String?
  email     String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String?

  // Indexes
  @@index([toolId])
}

model Bookmark {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String

  // Indexes
  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

model Post {
  id          String     @id @default(cuid(2))
  title       String     @db.Citext
  slug        String     @unique
  description String?
  content     String
  plainText   String     @default("")
  imageUrl    String?
  status      PostStatus @default(Draft)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // Indexes
  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}

// --- Causeartist models ---

model Company {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  status          String    @default("draft")
  tagline         String?
  description     String?   @db.Text
  logoUrl         String?
  website         String?
  foundedYear     Int?
  totalFunding    String?
  linkedin        String?
  twitter         String?
  founderName     String?
  impactModel     String?   @db.Text
  impactMetrics   String?   @db.Text
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sectors         CompanySector[]
  locations       CompanyLocation[]
  funders         CompanyFunder[]
  caseStudies     CaseStudy[]
  podcastEpisodes CompanyEpisode[]
}

model Funder {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  status           String    @default("draft")
  type             String?
  description      String?   @db.Text
  logoUrl          String?
  website          String?
  foundedYear      Int?
  aum              String?
  checkSizeMin     Int?
  checkSizeMax     Int?
  investmentThesis String?   @db.Text
  applicationUrl   String?
  linkedin         String?
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sectors          FunderSector[]
  stages           FunderStage[]
  locations        FunderLocation[]
  portfolio        CompanyFunder[]
  podcastEpisodes  FunderEpisode[]
}

model Sector {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  heroText  String?  @db.Text
  createdAt DateTime @default(now())
  companies CompanySector[]
  funders   FunderSector[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  companies CompanyLocation[]
  funders   FunderLocation[]
}

model FundingStage {
  id      String        @id @default(cuid())
  name    String
  slug    String        @unique
  funders FunderStage[]
}

model CompanySector {
  company   Company @relation(fields: [companyId], references: [id])
  companyId String
  sector    Sector  @relation(fields: [sectorId], references: [id])
  sectorId  String
  @@id([companyId, sectorId])
}

model CompanyLocation {
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  String
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
  @@id([companyId, locationId])
}

model CompanyFunder {
  company   Company @relation(fields: [companyId], references: [id])
  companyId String
  funder    Funder  @relation(fields: [funderId], references: [id])
  funderId  String
  @@id([companyId, funderId])
}

model FunderSector {
  funder   Funder @relation(fields: [funderId], references: [id])
  funderId String
  sector   Sector @relation(fields: [sectorId], references: [id])
  sectorId String
  @@id([funderId, sectorId])
}

model FunderStage {
  funder       Funder       @relation(fields: [funderId], references: [id])
  funderId     String
  fundingStage FundingStage @relation(fields: [stageId], references: [id])
  stageId      String
  @@id([funderId, stageId])
}

model FunderLocation {
  funder     Funder   @relation(fields: [funderId], references: [id])
  funderId   String
  location   Location @relation(fields: [locationId], references: [id])
  locationId String
  @@id([funderId, locationId])
}

model PodcastEpisode {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  status          String   @default("draft")
  episodeNumber   Int?
  description     String?  @db.Text
  content         String?  @db.Text
  heroImageUrl    String?
  spotifyUrl      String?
  appleUrl        String?
  youtubeUrl      String?
  excerpt         String?
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  companies       CompanyEpisode[]
  funders         FunderEpisode[]
}

model CompanyEpisode {
  company   Company        @relation(fields: [companyId], references: [id])
  companyId String
  episode   PodcastEpisode @relation(fields: [episodeId], references: [id])
  episodeId String
  @@id([companyId, episodeId])
}

model FunderEpisode {
  funder   Funder         @relation(fields: [funderId], references: [id])
  funderId String
  episode  PodcastEpisode @relation(fields: [episodeId], references: [id])
  episodeId String
  @@id([funderId, episodeId])
}

model CaseStudy {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  status          String    @default("draft")
  excerpt         String?
  content         String?   @db.Text
  heroImageUrl    String?
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company?  @relation(fields: [companyId], references: [id])
  companyId       String?
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  status          String    @default("draft")
  excerpt         String?
  content         String?   @db.Text
  heroImageUrl    String?
  seoTitle        String?
  seoDescription  String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  author          Author?   @relation(fields: [authorId], references: [id])
  authorId        String?
}

model GlossaryTerm {
  id               String   @id @default(cuid())
  term            String
  slug            String   @unique
  status          String   @default("draft")
  definition      String?  @db.Text
  extendedContent String?  @db.Text
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Author {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  bio       String?    @db.Text
  avatarUrl String?
  twitter   String?
  linkedin  String?
  createdAt DateTime  @default(now())
  posts     BlogPost[]
}
