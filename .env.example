# Must match BETTER_AUTH_URL (scheme + host + port) so magic links and the auth client use the same origin
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_EMAIL=""

# Database
# For build optimization, add connection pooling parameters:
# ?connection_limit=10&pool_timeout=30
DATABASE_URL="postgresql://root@localhost/dirstarter"

# Supabase Storage — use this for admin uploads (hero images, editor media). Leave S3_* empty.
# All three must be set. Same Supabase project as DATABASE_URL if you host Postgres there.
# 1) Dashboard → Settings → API → Project URL → SUPABASE_URL
# 2) Same page → service_role secret → SUPABASE_SERVICE_ROLE_KEY (not anon; server-only)
# 3) Dashboard → Storage → New bucket → SUPABASE_STORAGE_BUCKET (e.g. directory-media)
# 4) Public images: make bucket public or add Storage policy for anonymous SELECT on that bucket
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="directory-media"
# Optional CDN-style public prefix; must include /storage/v1/object/public/<bucket> if set
SUPABASE_STORAGE_PUBLIC_URL=""

# Cron Jobs
CRON_SECRET="xyz"

# BetterAuth — BETTER_AUTH_URL and NEXT_PUBLIC_SITE_URL must match the URL you open in the browser
BETTER_AUTH_SECRET="xyz" # generate with `openssl rand -base64 32`
BETTER_AUTH_URL="http://localhost:3000"

# Redis (Optional - falls back to in-memory rate limiting)
# Format: redis://[username:password@]host:port
REDIS_URL=""

# AI (Optional - uses Vercel AI Gateway, disabled if API key not set)
AI_GATEWAY_API_KEY=""
AI_CHAT_MODEL="openai/gpt-4o"
AI_COMPLETION_MODEL="openai/gpt-4o-mini"

# Web Scraping
JINA_API_KEY=""

# ScreenshotOne
SCREENSHOTONE_ACCESS_KEY=""

# Resend — required for magic-link emails to your inbox (both must be set)
RESEND_API_KEY=""
# Must be a verified domain/sender in Resend (e.g. onboarding@resend.dev for testing)
RESEND_SENDER_EMAIL="noreply@mail.example.com"
# Where contact form submissions are delivered (server-only)
CONTACT_INBOX_EMAIL="team@example.com"
# Optional — Resend dashboard segment id for newsletter contacts
RESEND_NEWSLETTER_SEGMENT_ID=""

# Plausible
NEXT_PUBLIC_PLAUSIBLE_URL="https://plausible.io"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"
PLAUSIBLE_API_KEY=""

# Amazon S3 (optional legacy — skip if you use Supabase Storage above)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
S3_ENDPOINT=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
