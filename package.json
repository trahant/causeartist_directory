{
  "name": "dirstarter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "node scripts/check-db-url.cjs && prisma migrate deploy && next build",
    "lint": "oxlint . --fix",
    "format": "oxfmt --write .",
    "email": "SKIP_ENV_VALIDATION=1 email dev",
    "db:generate": "prisma generate --no-hints",
    "db:migrate": "prisma migrate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push --skip-generate",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:seed:causeartist": "bun prisma/seed-causeartist.ts",
    "postinstall": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('npx prisma generate --no-hints',{stdio:'inherit'})}\""
  },
